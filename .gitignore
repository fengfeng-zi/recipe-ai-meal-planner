# Runtime-generated agent artifacts
/agent_runtime_harness/data/runs/*
!/agent_runtime_harness/data/runs/.gitkeep
/agent_runtime_harness/data/checkpoints/*
!/agent_runtime_harness/data/checkpoints/.gitkeep

