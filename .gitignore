# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local environment files
.env
.env.*
*.local

# Logs
*.log

